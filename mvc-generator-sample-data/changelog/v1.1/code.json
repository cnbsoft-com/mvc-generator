                      "primaryKey": true
                    }
                  }
                },
                {
                  "column": {
                    "name": "lang_cd",
                    "type": "${varcharType}(10)",
                    "remarks": "언어유형",
                    "constraints": {
                      "primaryKey": true
                    }
                  }
                },
                {
                  "column": {
                    "name": "code_group",
                    "type": "${varcharType}(100)",
                    "remarks": "코드 그룹",

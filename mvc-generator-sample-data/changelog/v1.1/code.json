        "id": "code-001",
        "author": "dino",
        "changes": [
          {
            "createSequence": {
              "sequenceName": "code_id_seq",
              "startValue": 1,
              "incrementBy": 1
            }
          },
          {
            "createTable": {
              "tableName": "code",
              "columns": [
                {
                  "column": {
                    "name": "id",
                    "type": "${seqType}",
                    "remarks": "고유식별자",

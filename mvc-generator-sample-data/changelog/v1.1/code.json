                      "primaryKey": true
                    }
                  }
                },
                {
                  "column": {
                    "name": "code_value",
                    "type": "${varcharType}(100)",
                    "remarks": "코드 값"
                  }
                },
                {
                  "column": {
                    "name": "use_yn",
                    "type": "${varcharType}(1)",
                    "remarks": "사용여부",
                    "defaultValue": "Y"
                  }
                },
                {
                  "column": {
                    "name": "ord",

                  }
                },
                {
                  "column": {
                    "name": "create_dt",
                    "type": "${datetimeType}",
                    "defaultValueDate": "${now}"
                  }
                },
                {
                  "column": {
                    "name": "edit_dt",
                    "type": "${datetimeType}",
                    "defaultValueDate": "${now}"
                  }
                }
              ]
            }
          },
          {
            "createIndex": {
              "tableName": "code",
              "indexName": "code_id_idx",
              "columns": [
                { "column": { "name": "id" } }
              ]
            }
          },

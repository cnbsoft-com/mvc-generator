{
  "databaseChangeLog": [
    {
      "changeSet": {
        "id": "user-group-type-001",
        "author": "dino",
        "changes": [
          {
            "createTable": {
              "tableName": "user_group_type",
              "columns": [
                {
                  "column": {
                    "name": "user_group",
                    "type": "${varcharType}(50)",
                    "remarks": "사용자 그룹 유형",
                    "constraints": {
                      "primaryKey": true
                    }
                  }
                },
                {
                  "column": {
                    "name": "user_group_name",
                    "type": "${varcharType}(100)",
                    "remarks": "사용자 그룹명",
                    "constraints": {
                      "nullable": false
                    }
                  }
                },
                {
                  "column": {
                    "name": "create_dt",
                    "type": "${datetimeType}",
                    "defaultValueDate": "${now}"
                  }
                },
                {
                  "column": {
                    "name": "edit_dt",
                    "type": "${datetimeType}",
                    "defaultValueDate": "${now}"
                  }
                }
              ]
            }
          }
        ]
      }
    },
    {
      "changeSet": {
        "id": "user-001",
        "author": "dino",
        "changes": [
          {
            "createTable": {
              "tableName": "user",
              "columns": [
                {
                  "column": {
                    "name": "id",
                    "type": "${uuidType}",
                    "remarks": "${uuidRemark}",
                    "constraints": {
                      "primaryKey": true
                    }
                  }
                },
                {
                  "column": {
                    "name": "username",
                    "type": "${varcharType}(100)",
                    "remarks": "사용자 아이디",
                    "constraints": {
                      "nullable": false
                    }
                  }
                },
                {
                  "column": {
                    "name": "password",
                    "type": "${varcharType}(100)",
                    "remarks": "비밀번호",
                    "constraints": {
                      "nullable": false
                    }
                  }
                },
                {
                  "column": {
                    "name": "email",
                    "type": "${varcharType}(100)",
                    "remarks": "이메일",
                    "constraints": {
                      "nullable": false
                    }
                  }
                },
                {
                  "column": {
                    "name": "credential_expired",
                    "type": "char(1)",
                    "defaultValue": "0",
                    "remarks": "인증 만료여부"
                  }
                },
                {
                  "column": {
                    "name": "expired",
                    "type": "char(1)",
                    "defaultValue": "0",
                    "remarks": "만료여부"
                  }
                },
                {
                  "column": {
                    "name": "locked",
                    "type": "char(1)",
                    "defaultValue": "0",
                    "remarks": "잠금여부"
                  }
                },
                {
                  "column": {
                    "name": "enabled",
                    "type": "char(1)",
                    "defaultValue": "1",
                    "remarks": "사용여부"
                  }
                },
                {
                  "column": {
                    "name": "create_dt",
                    "type": "${datetimeType}",
                    "defaultValueDate": "${now}"
                  }
                },
                {
                  "column": {
                    "name": "edit_dt",
                    "type": "${datetimeType}",
                    "defaultValueDate": "${now}"
                  }
                }
              ]
            }
          },
          {
            "createIndex": {
              "tableName": "user",
              "indexName": "username_idx",
              "columns": [
                { "column": { "name": "username" } }
              ]
            }
          }
        ]
      }
    },

    {
      "changeSet": {
        "id": "user-login-log-001",
        "author": "dino",
        "changes": [
          {
            "createTable": {
              "tableName": "user_login_log",
              "columns": [
                {
                  "column": {
                    "name": "id",
                    "type": "${uuidType}",
                    "constraints": {
                      "primaryKey": true
                    }
                  }
                },
                {
                  "column": {
                    "name": "username",
